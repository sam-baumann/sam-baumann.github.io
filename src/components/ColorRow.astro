---
interface Props {
    title: string;
    bgClasses: string[];    
}

const {title, bgClasses} = Astro.props
---
<div class="flex flex-row items-center gap-2">
    <span>{title}</span>

    {bgClasses.map((cls) => (
      <div class={`group relative m-1 p-3 border rounded-sm ${cls}`}>
        <div
          class="pointer-events-none absolute left-1/2 top-full z-10 mt-2 -translate-x-1/2
                 whitespace-nowrap rounded bg-neutral-900 px-2 py-1 text-xs text-white
                 opacity-0 transition-opacity group-hover:opacity-100"
        >
          {cls}
        </div>
      </div>
    ))}
  </div>